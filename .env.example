```# PostgreSQL Configuration
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=bigdata
POSTGRES_USER=user
POSTGRES_PASSWORD=pass

# DuckDB Configuration
DUCKDB_PATH=:memory:
DATA_PATH=data/raw
LOG_LEVEL=INFO
LOG_FILE=logs/bgd.log

# Processing Configuration
USE_DUCKDB=false
USE_DBT=false
MAX_WORKERS=4
DUCKDB_THREADS=4

# Redis Configuration (for streaming)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# Queue Configuration
QUEUE_NAME=bgd_ingestion
BATCH_SIZE=1000
MAX_QUEUE_SIZE=10000

# File Watcher Configuration
WATCH_PATH=data/raw
WATCH_PATTERN=*.parquet
POLL_INTERVAL=1.0

# Ingestion Trigger Configuration
INGESTION_TRIGGER=file  # file, schedule, manual
SCHEDULE_INTERVAL=*/5 * * * *  # cron expression

# Processing Configuration (streaming)
PROCESSING_WORKERS=4
PROCESSING_TIMEOUT=300

# Database Configuration
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=bigdata
POSTGRES_USER=user
POSTGRES_PASSWORD=pass

# DuckDB Configuration
DUCKDB_PATH=:memory:  # ':memory:' for in-memory or path to file

# Pipeline Configuration
DATA_PATH=data/raw
LOG_LEVEL=INFO
LOG_FILE=logs/bgd.log

# Feature Flags (enable new pipeline)
USE_DAGSTER=true
USE_DUCKDB=true
USE_DBT=true

# Connection URLs
# DATABASE_URL=postgresql://user:pass@localhost:5432/bigdata
<mxfile host="app.diagrams.net">
  <diagram name="Architecture">
    <mxGraphModel dx="1100" dy="700" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>

        <mxCell id="source" value="Kaggle Dataset" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e8f5e9;" vertex="1" parent="1">
          <mxGeometry x="60" y="60" width="180" height="60" as="geometry"/>
        </mxCell>

        <mxCell id="bronze" value="Bronze (Postgres)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;" vertex="1" parent="1">
          <mxGeometry x="300" y="60" width="180" height="60" as="geometry"/>
        </mxCell>

        <mxCell id="silver" value="Silver (Postgres)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1f5fe;" vertex="1" parent="1">
          <mxGeometry x="540" y="60" width="180" height="60" as="geometry"/>
        </mxCell>

        <mxCell id="gold" value="Gold (Postgres)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff8e1;" vertex="1" parent="1">
          <mxGeometry x="780" y="60" width="180" height="60" as="geometry"/>
        </mxCell>

        <mxCell id="e1" style="edgeStyle=orthogonalEdgeStyle;rounded=0;endArrow=block;" edge="1" parent="1" source="source" target="bronze">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <mxCell id="e2" style="edgeStyle=orthogonalEdgeStyle;rounded=0;endArrow=block;" edge="1" parent="1" source="bronze" target="silver">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <mxCell id="e3" style="edgeStyle=orthogonalEdgeStyle;rounded=0;endArrow=block;" edge="1" parent="1" source="silver" target="gold">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
